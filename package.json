{
    "name": "currency-piggybank",
    "version": "1.0.0",
    "type": "module",
    "main": "src/server.ts",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "start": "tsx src/server.ts",
        "build:client": "esbuild src/frontend/app.ts --bundle --format=iife --target=es2020 --outfile=public/js/app.js",
        "watch:client": "esbuild src/frontend/app.ts --bundle --format=iife --target=es2020 --outfile=public/js/app.js --watch",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "dotenv": "^17.4.2",
        "express": "^4.21.2",
        "node-fetch": "^3.3.2",
        "pg": "^8.22.0",
        "sqlite": "^5.1.1",
        "sqlite3": "^6.0.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^26.0.0",
        "@types/pg": "^8.20.0",
        "@types/sqlite3": "^3.1.11",
        "esbuild": "^0.28.1",
        "prettier": "^3.8.4",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}
